@page "{id:int?}"
@model RazorPagesMeme.Pages.Memes.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Meme</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Meme.Id" />
            <div class="form-group">
                <label asp-for="Meme.Name" class="control-label"></label>
                <input asp-for="Meme.Name" class="form-control" />
                <span asp-validation-for="Meme.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meme.Date" class="control-label"></label>
                <input asp-for="Meme.Date" class="form-control" />
                <span asp-validation-for="Meme.Date" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meme.Origin" class="control-label"></label>
                <input asp-for="Meme.Origin" class="form-control" />
                <span asp-validation-for="Meme.Origin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meme.Funniness" class="control-label"></label>
                <input asp-for="Meme.Funniness" class="form-control" />
                <span asp-validation-for="Meme.Funniness" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Meme.CelebrityEndorsement" class="control-label"></label>
                <input asp-for="Meme.CelebrityEndorsement" class="form-control" />
                <span asp-validation-for="Meme.CelebrityEndorsement" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
